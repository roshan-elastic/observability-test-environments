{
  "applications": [
    {
      "application": "kibana-.kibana",
      "privileges": [
        "feature_apm.all",
        "feature_logs.all",
        "feature_infrastructure.all",
        "feature_ml.all",
        "feature_uptime.all"
      ],
      "resources": [
        "*"
      ]
    }
  ],
  "transient_metadata": {
    "enabled": true
  },
  "run_as": [],
  "cluster": [],
  "indices": [
    {
      "privileges": [
        "read",
        "view_index_metadata"
      ],
      "allow_restricted_indices": false,
      "names": [
        "apm-*",
        "logs-apm*",
        "metrics-apm*",
        "traces-apm*"
      ]
    },
    {
      "privileges": [
        "read",
        "write",
        "view_index_metadata"
      ],
      "allow_restricted_indices": false,
      "names": [
        "observability-annotations"
      ]
    },
    {
      "privileges": [
        "read",
        "view_index_metadata"
      ],
      "allow_restricted_indices": false,
      "names": [
        "logs-*",
        "filebeat-*",
        "kibana_sample_data_logs*"
      ]
    },
    {
      "privileges": [
        "read",
        "view_index_metadata"
      ],
      "allow_restricted_indices": false,
      "names": [
        "metrics-*",
        "metricbeat-*"
      ]
    },
    {
      "privileges": [
        "read",
        "view_index_metadata"
      ],
      "allow_restricted_indices": false,
      "names": [
        "heartbeat-*",
        "synthetics-*"
      ]
    }
  ],
  "metadata": {
    "version": 1
  }
}
