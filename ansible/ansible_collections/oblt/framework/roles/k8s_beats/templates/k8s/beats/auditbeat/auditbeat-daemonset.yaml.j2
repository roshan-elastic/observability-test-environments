---
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: auditbeat
  namespace: "{{ kube_system_namespace }}"
  labels:
    k8s-app: auditbeat
spec:
  selector:
    matchLabels:
      k8s-app: auditbeat
  updateStrategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        k8s-app: auditbeat
    spec:
      serviceAccountName: auditbeat
      hostPID: true
      terminationGracePeriodSeconds: 30
      dnsPolicy: ClusterFirstWithHostNet
      automountServiceAccountToken: true
      initContainers:
      - name: wait-for-service
        image: curlimages/curl:latest
        command: ['sh', '-c', 'until curl -LksS -u ${ELASTICSEARCH_USERNAME}:${ELASTICSEARCH_PASSWORD} ${ELASTICSEARCH_HOST}; do echo waiting for ${ELASTICSEARCH_HOST}; sleep 2; done;']
        envFrom:
          - secretRef:
              name: es-creds
      containers:
      - name: auditbeat
        image: {{ beats.auditbeat.image }}
        imagePullPolicy: Always
        securityContext:
          runAsUser: 0
          capabilities:
            add:
            - AUDIT_CONTROL
            - AUDIT_READ
            - NET_ADMIN
        args: [ "-c", "/etc/auditbeat.yml", "-e", "-d", "add_docker_metadata" ]
        envFrom:
          - secretRef:
              name: es-creds
          - secretRef:
              name: apm-creds
          - secretRef:
              name: kibana-creds
        env:
        - name: ELASTIC_APM_ACTIVE
          value: 'true'
        - name: DEPLOY_TIMESTAMMP
          value: "{{ deploy_timestamp }}"
        - name: NODE_NAME
          valueFrom:
            fieldRef:
              fieldPath: spec.nodeName
        resources:
          limits:
            memory: 200Mi
          requests:
            cpu: 0.05
            memory: 100Mi
        volumeMounts:
        - name: config
          mountPath: /etc/auditbeat.yml
          readOnly: true
          subPath: auditbeat.yml
        - name: dockersock
          mountPath: /var/run/docker.sock
        - name: proc
          mountPath: /hostfs/proc
          readOnly: true
      volumes:
      - name: config
        configMap:
          defaultMode: 0600
          name: auditbeat-config
      - name: data
        hostPath:
          path: /var/lib/auditbeat-data
          type: DirectoryOrCreate
      - name: proc
        hostPath:
          path: /proc
      - name: dockersock
        hostPath:
          path: /var/run/docker.sock
      imagePullSecrets:
        - name: docker.elastic.co
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: auditbeat
subjects:
- kind: ServiceAccount
  name: auditbeat
  namespace: "{{ kube_system_namespace }}"
roleRef:
  kind: ClusterRole
  name: auditbeat
  apiGroup: rbac.authorization.k8s.io
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: auditbeat
  labels:
    k8s-app: auditbeat
rules:
- apiGroups: [""]
  resources:
  - nodes
  - namespaces
  - events
  - pods
  verbs: ["get", "list", "watch"]
- apiGroups: ["extensions"]
  resources:
  - replicasets
  verbs: ["get", "list", "watch"]
- apiGroups: ["apps"]
  resources:
  - statefulsets
  - deployments
  verbs: ["get", "list", "watch"]
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: auditbeat
  namespace: "{{ kube_system_namespace }}"
  labels:
    k8s-app: auditbeat
---
