---
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: heartbeat
  namespace: "{{ kube_system_namespace }}"
  labels:
    k8s-app: heartbeat
spec:
  selector:
    matchLabels:
      k8s-app: heartbeat
  updateStrategy:
    type: RollingUpdate
  template:
    metadata:
      labels:
        k8s-app: heartbeat
        app: beat
    spec:
      serviceAccountName: heartbeat
      terminationGracePeriodSeconds: 60
      dnsPolicy: ClusterFirstWithHostNet
      automountServiceAccountToken: true
      initContainers:
      - name: wait-for-service
        image: curlimages/curl:latest
        command: ['sh', '-c', 'until curl -LksS -u ${ELASTICSEARCH_USERNAME}:${ELASTICSEARCH_PASSWORD} ${ELASTICSEARCH_HOST}; do echo waiting for ${ELASTICSEARCH_HOST}; sleep 2; done;']
        envFrom:
          - secretRef:
              name: es-creds
      containers:
      - name: heartbeat
        image: docker.elastic.co/observability-ci/heartbeat:8.0.0-SNAPSHOT
        imagePullPolicy: Always
        envFrom:
          - secretRef:
              name: es-creds
          - secretRef:
              name: apm-creds
          - secretRef:
              name: kibana-creds
        env:
        - name: ELASTIC_APM_ACTIVE
          value: 'true'
        - name: DEPLOY_TIMESTAMP
          value: "{{ deploy_timestamp }}"
        - name: NODE_NAME
          valueFrom:
            fieldRef:
              fieldPath: spec.nodeName
        securityContext:
          runAsUser: 0
        resources:
          limits:
            memory: 200Mi
          requests:
            cpu: 0.05
            memory: 64Mi
        volumeMounts:
        - name: config
          mountPath: /usr/share/heartbeat/heartbeat.yml
          readOnly: true
          subPath: heartbeat.yml
      volumes:
      - name: config
        configMap:
          defaultMode: 0600
          name: heartbeat-config
      - name: data
        emptyDir: {}
      imagePullSecrets:
        - name: docker.elastic.co
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: heartbeat
subjects:
- kind: ServiceAccount
  name: heartbeat
  namespace: "{{ kube_system_namespace }}"
roleRef:
  kind: ClusterRole
  name: heartbeat
  apiGroup: rbac.authorization.k8s.io
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: heartbeat
  namespace: "{{ kube_system_namespace }}"
  labels:
    k8s-app: heartbeat
