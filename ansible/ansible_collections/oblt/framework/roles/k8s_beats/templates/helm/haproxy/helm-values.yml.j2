---
fullnameOverride: haproxy
replicaCount: 2
service:
  type: ClusterIP

configuration: |
  global
    log stdout  format raw  local0
  defaults
    log global
    option httplog
    timeout client  30s
    timeout server  30s
    timeout connect 30s

  frontend apacheFrontend
    bind  :8080
    default_backend apacheBackend

  backend apacheBackend
    mode  http
    server  apacheServer apache:80

resources:
  requests:
    memory: 128Mi
    cpu: 0.05
  limits:
    memory: 256Mi
