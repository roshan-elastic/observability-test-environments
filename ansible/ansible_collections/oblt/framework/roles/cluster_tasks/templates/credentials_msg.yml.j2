*Credentials*

{% if k8s_enabled and (ingress_enabled | default(false)) %}
ingress:
  username: {{ ingress_username | default(None) }}
  password: {{ ingress_password | default(None) }}
{% endif %}
{% if elasticsearch_enabled %}
elasticsearch:
  login url: {{ elasticsearch_url }}
  username: {{ elasticsearch_username | default(None) }}
  password: {{ elasticsearch_password | default(None) }}

  curl -kv -u {{ elasticsearch_username }}:{{ elasticsearch_password }} {{ elasticsearch_url }}

  {{ lookup('ansible.builtin.template', '{{ templates_dir }}/user_msg.yml.j2') | indent(2) }}
