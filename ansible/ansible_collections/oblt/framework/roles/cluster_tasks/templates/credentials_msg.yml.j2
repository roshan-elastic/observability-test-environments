{% if kibana_enabled %}
kibana:
  url: {{ kibana_url }}
  username: {{ kibana_username | default(None) }}
  password: {{ kibana_password | default(None) }}

  {% if (ess_saml_id |default('')) != 'disabled' %}
  This Kibana deployment has Okta login enabled, you can use Okta to login to Kibana.
  {% endif %}

  Check oblt-cli documentation to <https://elastic.github.io/observability-test-environments/tools/oblt-cli/local-kibana/ | know hot to connect a local Kibana instance>
{% endif %}
{% if apm_enabled %}
apm:
  url: {{ apm_url }}
{% if apm_token is defined and (apm_token|length) >0 %}
  token: {{ apm_token }}

  curl -kv -H "Authorization: Bearer {{ apm_token }}" {{ apm_url }}
{% endif %}
{% if apm_apikey is defined and (apm_apikey|length) >0%}
  api_key: {{ apm_apikey | default(None) }}

  curl -kv -H "Authorization: ApiKey {{ apm_apikey }}" {{ apm_url }}
{% endif %}


{% endif %}
{% if k8s_enabled and (opbeans_enabled | default(false)) %}
opbeans:
  username: {{ ingress_username | default(None) }}
  password: {{ ingress_password | default(None) }}
{% endif %}
