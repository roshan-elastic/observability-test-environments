# minimal helm values for a deployment

image:
  # -- Docker image of the Elastic Agent.
  name: docker.elastic.co/observability-ci/elastic-agent
  # -- Tag for the Docker image.
  tag: "{{ stack_version }}"
  # -- Pull Docker images policy [IfNotPresent, Always, Never].
  pullPolicy: IfNotPresent
  pullSecrets:
    - name: docker.elastic.co

# -- Elastic Agent deployment type [deploymnent, daemonset, standalone]
mode: managed

# -- Elastic Agent settings.
fleet:
  # -- To ensure that enrollment occurs on every start of the container set `fleet.force` to true.
  force: true
  # -- set to `true` for enrollment into fleet-server. If not set, Elastic Agent is run in standalone mode.
  enroll: true
  # -- communicate with Fleet with either insecure HTTP or unverified HTTPS.
  insecure: false
  # -- URL of the Fleet Server to enroll into (e.g. https://fleet-server:8220).
  serverUrl: "{{ fleet_url  }}"
  enrollToken: "{{ fleet_enroll_token }}"

fullnameOverride: {{ helm_chart.name }}-{{ cluster_hash }}

serviceAccount:
  name: {{ helm_chart.name }}-{{ cluster_hash }}
