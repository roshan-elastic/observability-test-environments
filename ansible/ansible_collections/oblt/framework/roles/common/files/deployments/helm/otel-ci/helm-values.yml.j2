    JCasC:
      enabled: true
      defaultConfig: false
      configScripts:
        jcasc-config: |
          jenkins:
            numExecutors: 0
            systemMessage: "Jenkins configured automatically by Jenkins Configuration as Code plugin\n\n"
            agentProtocols:
            - "JNLP4-connect"
            - "Ping"
            authorizationStrategy:
              loggedInUsersCanDoAnything:
                          allowAnonymousRead: false
            securityRealm:
              local:
                allowsSignup: false
                enableCaptcha: false
                users:
                - id: "admin"
                  name: "Administrator"
                  password: "${jenkins-secrets-password}"
                  properties:
                  - mailer:
                      emailAddress: "kuisathaverat@gmail.com"
            slaveAgentPort: 50000
            clouds:
            - kubernetes:
                containerCap: 10
                containerCapStr: "10"
                jenkinsUrl: "http://otel-ci-jenkins:8080"
                name: "kubernetes"
                podRetention: "onFailure"
                webSocket: true
                templates:
                - containers:
                  - args: "9999999"
                    command: "sleep"
                    image: "ubuntu:20.04"
                    livenessProbe:
                      failureThreshold: 0
                      initialDelaySeconds: 0
                      periodSeconds: 0
                      successThreshold: 0
                      timeoutSeconds: 0
                    name: "ubuntu-20"
                    workingDir: "/home/jenkins/agent"
                  id: "079597dc-582a-438d-9f3c-70e0d093d6c6"
                  label: "ubuntu20 ubuntu linux k8s"
                  name: "ubuntu20"
                  yamlMergeStrategy: "override"
                - containers:
                  - alwaysPullImage: true
                    args: "9999999"
                    command: "sleep"
                    image: "kuisathaverat/maven"
                    livenessProbe:
                      failureThreshold: 0
                      initialDelaySeconds: 0
                      periodSeconds: 0
                      successThreshold: 0
                      timeoutSeconds: 0
                    name: "maven-cache"
                    ttyEnabled: true
                    workingDir: "/home/jenkins/agent"
                  - alwaysPullImage: true
                    args: "-H tcp://localhost:2375 -H unix:///var/lib/docker/docker.sock"
                    command: "dockerd"
                    envVars:
                    - envVar:
                        key: "DOCKER_TLS_CERTDIR"
                    image: "docker:20.10.14-dind"
                    livenessProbe:
                      failureThreshold: 0
                      initialDelaySeconds: 0
                      periodSeconds: 0
                      successThreshold: 0
                      timeoutSeconds: 0
                    name: "dind"
                    ports:
                    - containerPort: 2376
                      hostPort: 2376
                      name: "docker-api"
                    privileged: true
                    ttyEnabled: true
                    workingDir: "/home/jenkins/agent"
                  - alwaysPullImage: true
                    args: "9999999"
                    command: "sleep"
                    image: "kuisathaverat/tools"
                    livenessProbe:
                      failureThreshold: 0
                      initialDelaySeconds: 0
                      periodSeconds: 0
                      successThreshold: 0
                      timeoutSeconds: 0
                    name: "ansible"
                    ttyEnabled: true
                    workingDir: "/home/jenkins/agent"
                  envVars:
                  - envVar:
                      key: "DOCKER_HOST"
                      value: "tcp://localhost:2375"
                  id: "f672bc79-2549-4b96-8ecd-63fc82506ad1"
                  label: "maven"
                  name: "maven"
                  volumes:
                  - emptyDirVolume:
                      memory: false
                      mountPath: "/var/lib/docker"
                  yamlMergeStrategy: "override"
        unclassified: |
