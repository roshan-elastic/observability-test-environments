            - file: "/usr/share/jenkins/ref/jobs/devops-world-2022-load-gen.dsl"
        opentelemetry: |
          unclassified:
            openTelemetry:
              authentication: "noAuthentication"
              endpoint: "http://otel-collector-contrib.default.svc.cluster.local:4317"
              exportOtelConfigurationAsEnvironmentVariables: false
              exporterIntervalMillis: 60000
              exporterTimeoutMillis: 30000
              ignoredSteps: "dir,echo,fileExists,isUnix,pwd,properties,readFile,readYaml,writeFile"
              observabilityBackends:
              - elastic:
                  displayKibanaDashboardLink: true
                  elasticLogsBackend:
                    elasticLogsBackendWithJenkinsVisualization:
                      elasticsearchCredentialsId: "elasticsearch-logs-creds"
                      elasticsearchUrl: {{ elasticsearch_url }}
                  kibanaBaseUrl: {{ kibana_url }}
              serviceName: "jenkins"
              serviceNamespace: "jenkins"
        slack: |
          unclassified:
            slackNotifier:
              botUser: false
              sendAsText: false
              teamDomain: "elastic-s819326"
              tokenCredentialId: "jenkins-slack-integration-token"
    ingress:
      enabled: true
      apiVersion: networking.k8s.io/v1
      annotations:
        cert-manager.io/cluster-issuer: "letsencrypt-prod"
        nginx.ingress.kubernetes.io/proxy-body-size: 25m
        ingress.kubernetes.io/ssl-redirect: "true"
        kubernetes.io/ingress.class: nginx
        kubernetes.io/tls-acme: "true"
        nginx.ingress.kubernetes.io/auth-type: basic
        nginx.ingress.kubernetes.io/auth-secret: elastic-basic-auth
        nginx.ingress.kubernetes.io/auth-realm: "Authentication Required"
      hostName: {{ jenkins_host }}
