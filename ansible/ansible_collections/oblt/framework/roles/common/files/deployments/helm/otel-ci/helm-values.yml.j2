    maxRequestsPerHostStr: "100"
  persistence:
    enabled: true
    size: "80Gi"
    volumes:
      - name: jenkins-jobs
        configMap:
          name: jenkins-jobs
    mounts:
      - mountPath: /usr/share/jenkins/ref/jobs
        name: jenkins-jobs
  # kubernetes-credentials-provider-plugin
  # https://jenkinsci.github.io/kubernetes-credentials-provider-plugin/
  rbac:
    create: true
    readSecrets: true

velero:
  configuration:
    provider: gcp
    backupStorageLocation:
      bucket: jenkins-otel
  initContainers:
    - name: velero-plugin-for-gcp
      image: velero/velero-plugin-for-gcp:v1.2.0
      imagePullPolicy: IfNotPresent
      volumeMounts:
        - mountPath: /target
          name: plugins
  schedules:
    jenkins:
      schedule: 0 0 * * *
      template:
        includedNamespaces:
          - default
        # labelSelector:
        #   matchLabels:
        #     app.kubernetes.io/instance: jenkins
        includedResources:
          - pv
          - pvc
        ttl: 120h0m0s
  credentials:
    secretContents:
      cloud: |
        {{ lookup('file', build_dir + '/gcp/credentials.json') }}
