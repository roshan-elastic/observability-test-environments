{% set jenkins_host = 'jenkins.' + load_balancer_ip + '.' + k8s.domain -%}
# Default values for otel_ci.
# This is a YAML-formatted file.
# Declare variables to be passed into your templates.

opentelemetry-collector:
  fullnameOverride: otel-collector-contrib
  image:
    repository: otel/opentelemetry-collector-contrib
    pullPolicy: Always
    tag: "0.60.0"
  mode: deployment
  service:
    type: ClusterIP
  extraEnvs:
    - name: ELASTIC_APM_SECRET_TOKEN
      valueFrom:
        secretKeyRef:
          name: apm-creds
          key: token
    - name: ELASTIC_APM_SERVER_URL
      valueFrom:
        secretKeyRef:
          name: apm-creds
          key: url
  config:
    receivers:
      otlp:
        protocols:
          grpc:
          http:
      hostmetrics:
        collection_interval: 1m
        scrapers:
          cpu:
          load:
          memory:
    processors:
      batch:
    exporters:
      otlp/elastic:
        endpoint: "${ELASTIC_APM_SERVER_URL}"
        headers:
          Authorization: "Bearer ${ELASTIC_APM_SECRET_TOKEN}"
      logging:
        loglevel: debug
    service:
      extensions: [zpages, health_check]
      pipelines:
        metrics:
          receivers: [otlp, hostmetrics]
          exporters: [logging, otlp/elastic]
        traces:
          receivers: [otlp]
          processors: [batch]
          exporters: [logging, otlp/elastic]
        logs:
          receivers: [otlp]
          exporters: [logging, otlp/elastic]
    extensions:
      health_check:
      zpages:

