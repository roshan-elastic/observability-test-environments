{
	"blocks": [
		{
			"type": "section",
			"text": {
				"type": "mrkdwn",
				"text": "Hey there 👋 I'm oblt-robot. I'm here to help you with Oblt Clusters, CI and some automation!\n"
			}
		},
		{
			"type": "header",
			"text": {
				"type": "plain_text",
				"text": "List of Releases or Build Candidates in the Unified Release process are",
				"emoji": true
			}
		},
  	{{ $length := len .Releases }}
  	{{ if eq $length 0 }}
		{
			"type": "section",
			"text": {
				"type": "mrkdwn",
				"text": ":ghost: No releases could be found. Contact the `@oblt-robots` team"
			}
		},
    {{else}}
		{{ range $version := .Releases }}
		{
			"type": "section",
			"fields": [
				{
					"type": "mrkdwn",
					"text": "*Build:*`{{ $version.BuildId }}` {{ $version.Version }}"
				},
				{
					"type": "mrkdwn",
					"text": "*Date:*`{{ $version.ReleaseDate }}` <{{ $version.Query }}|View request>"
				}
			]
		},
    {{ end }}
    {{ end }}
		{
			"type": "divider"
		}
	]
}
